{
  "manifest_version": 3,
  "name": "PG Reader",
  "version": "2.1.0",
  "description": "Readable layout, semantic HTML, and click-to-reveal footnotes for Paul Graham's essays.",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://www.paulgraham.com/*",
        "*://paulgraham.com/*"
      ],
      "css": [
        "content.css"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "PG Reader",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["fonts/*"],
      "matches": ["*://www.paulgraham.com/*", "*://paulgraham.com/*"]
    }
  ]
}